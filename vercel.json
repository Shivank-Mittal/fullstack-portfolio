{
  "version": 2,
  "routes": [
    {
      "src": "^/fr/(.*\\.(js|css|png|jpg|ico|svg))$",
      "dest": "/dist/porfolio/browser/fr-FR/$1"
    },
    {
      "src": "^/en/(.*\\.(js|css|png|jpg|ico|svg))$",
      "dest": "/dist/porfolio/browser/en-US/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/ssr"
    }
  ]

}